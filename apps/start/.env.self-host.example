# ------------------------------------------------------------
# RIFT Environment Variables - Self-Hosted
# ------------------------------------------------------------
# Notes:
# - Required means the app cannot run key paths without it.
# - Optional means feature-specific.
# - Self-hosted mode removes Stripe, anon users, and quota limits.

# ============================================================
# 1) Core Data + Auth (REQUIRED)
# ============================================================

# App instance mode
VITE_APP_INSTANCE_MODE=self_hosted

# Public app origin
BETTER_AUTH_URL=https://example.com
VITE_BETTER_AUTH_URL=https://example.com

BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Change this with a secure password, You will Require it the first time you load the app to create the initial admin user.
SELF_HOSTED_SETUP_TOKEN=replace-with-a-secure-password


# ============================================================
# 2) Zero & Database (REQUIRED)
# ============================================================

# Primary Postgres used by Zero server adapter.
ZERO_UPSTREAM_DB=postgresql://postgres:postgres@postgres.railway.internal:5432/rift
VITE_ZERO_CACHE_URL=https://zero.example.com

ZERO_QUERY_URL=https://example.com/api/zero/query
ZERO_MUTATE_URL=https://example.com/api/zero/mutate
# Forward browser cookies to query/mutate endpoints.
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true


# ============================================================
# 3) File Upload + Markdown Conversion (REQUIRED for attachments)
# ============================================================
# Choose storage backend:
# - cloudflare_r2
# - s3_compatible (recommended for Railway)
UPLOAD_STORAGE_PROVIDER=s3_compatible
# Cloudflare R2 settings (required when 'provider=cloudflare_r2').
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# S3-compatible settings (required when 'provider=s3_compatible').
S3_ENDPOINT=https://storage.railway.app
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET_NAME=rift
S3_REGION=auto
# Optional override if you serve files via an external public domain.
# If omitted, defaults to ${BETTER_AUTH_URL}/api/files/object (signed proxy).
S3_PUBLIC_BASE_URL=

# Cloudflare Worker Markdown conversion. (REQUIRED)
# To set up the worker, run: bun setup:markdown-worker
# This will deploy the worker and generate the token automatically.
CF_MARKDOWN_WORKER_URL=
CF_MARKDOWN_WORKER_TOKEN=

# ============================================================
# 4) AI Model Access (REQUIRED for chat/title generation)
# ============================================================
# AI Gateway (used by AI SDK gateway model IDs).
AI_GATEWAY_API_KEY=


# ============================================================
# 5) Global Feature Toggles
# ============================================================
# false => disable embeddings + vector retrieval/indexing globally.
VITE_ENABLE_EMBEDDING=true
# false => disable organization BYOK API key management globally.
VITE_ENABLE_ORGANIZATION_PROVIDER_KEYS=true
# Allow exposing AI cost data to end users. (BYOK requests display the cost even if set to 'false').
ALLOW_USER_COST_DISPLAY=true
# Disable Redis for stream resume (use in-memory fallback).
VITE_DISABLE_REDIS=true

# ============================================================
# 6) Chat Streaming (REQUIRED when ENABLE_REDIS=true)
# ============================================================
REDIS_URL=redis://default:password@redis.railway.internal:6379


# ============================================================
# 7) Vector Store (Optional when ENABLE_EMBEDDING=true)
# ============================================================
QDRANT_URL=

# Optional if Qdrant auth is enabled.
QDRANT_API_KEY=