# Core app runtime
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000
VITE_APP_INSTANCE_MODE=cloud
VITE_ENABLE_GUEST_ACCESS=false
VITE_ZERO_CACHE_URL=http://localhost:4848
# Zero requires an upstream Postgres instance where SHOW wal_level returns
# `logical`. Railway's managed Postgres currently reports `replica`, so use a
# logical-replication-capable Postgres provider or a self-managed Postgres
# service for ZERO_UPSTREAM_DB.
ZERO_UPSTREAM_DB=postgres://bish:bish@localhost:5432/bish
REDIS_URL=redis://localhost:6379

# BISH connector security
# Use either a 32-character plain secret or base64 that decodes to 32 bytes.
BISH_ENCRYPTION_KEY=replace-with-32-byte-secret

# Operator access
BISH_OPERATOR_EMAILS=operator@example.com

# Google Workspace delegation
GOOGLE_WORKSPACE_PROJECT_ID=
GOOGLE_WORKSPACE_CLIENT_EMAIL=
GOOGLE_WORKSPACE_PRIVATE_KEY=
GOOGLE_WORKSPACE_IMPERSONATION_ADMIN=

# Google Drive Picker OAuth
GOOGLE_PICKER_CLIENT_ID=
GOOGLE_PICKER_CLIENT_SECRET=
GOOGLE_PICKER_REDIRECT_URI=http://localhost:3000/api/org/knowledge/google/callback

# Asana OAuth
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=http://localhost:3000/api/org/bish/connectors/asana/callback

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/org/bish/connectors/hubspot/callback

# File ingestion
CF_MARKDOWN_WORKER_URL=
CF_MARKDOWN_WORKER_TOKEN=

# Optional tuning
BISH_WORKER_POLL_MS=5000
BISH_SCHEDULER_INTERVAL_MS=60000
BISH_SYNC_STALE_MS=300000

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_SETUP=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_SETUP=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_SETUP=
# Optional metered overage / seat expansion placeholders.
STRIPE_PRICE_AI_OVERAGE_METERED=
STRIPE_PRICE_PLUS_ADDITIONAL_SEAT=
STRIPE_PRICE_PRO_ADDITIONAL_SEAT=
STRIPE_PRICE_SCALE_ADDITIONAL_SEAT=
