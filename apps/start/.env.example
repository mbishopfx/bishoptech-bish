# ------------------------------------------------------------
# RIFT Environment Variables
# ------------------------------------------------------------
# Notes:
# - Required means the app cannot run key paths without it.
# - Optional means feature-specific.
# - If ENABLE_EMBEDDING=false, Qdrant vars are not required.

# ============================================================
# 1) Core Data + Auth (REQUIRED)
# ============================================================

# Better Auth (required for authenticated API routes / chat).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000

BETTER_AUTH_COOKIE_DOMAIN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Required for Better Auth verification/reset emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=


# ============================================================
# 2) Zero & Database (REQUIRED) - For Local Development, Zero requires separate '.env' file.
# ============================================================

# Primary Postgres used by Zero server adapter.
ZERO_UPSTREAM_DB=
VITE_ZERO_CACHE_URL=http://localhost:4848

ZERO_QUERY_URL=http://localhost:3000/api/zero/query
ZERO_MUTATE_URL=http://localhost:3000/api/zero/mutate
# Forward browser cookies to query/mutate endpoints.
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true


# ============================================================
# 3) File Upload + Markdown Conversion (REQUIRED for attachments)
# ============================================================
# Choose storage backend:
# - cloudflare_r2
# - s3_compatible
UPLOAD_STORAGE_PROVIDER=cloudflare_r2
# Cloudflare R2 settings (required when provider=cloudflare_r2).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# S3-compatible settings (required when provider=s3_compatible).
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto
# Optional override if you serve files via an external public domain.
# If omitted, defaults to ${BETTER_AUTH_URL}/api/files/object (signed proxy).
S3_PUBLIC_BASE_URL=

# Cloudflare Worker Markdown conversion.
CF_MARKDOWN_WORKER_URL=
CF_MARKDOWN_WORKER_TOKEN=

# Optional conversion timeout in ms.
CF_MARKDOWN_WORKER_TIMEOUT_MS=20000

# Optional max markdown characters per file.
CF_MARKDOWN_MAX_CHARS=120000


# ============================================================
# 4) Chat Streaming Infrastructure (REQUIRED for stream resume)
# ============================================================
REDIS_URL=


# ============================================================
# 5) AI Model Access (REQUIRED for chat/title generation)
# ============================================================
# AI Gateway (used by AI SDK gateway model IDs).
AI_GATEWAY_API_KEY=

# Optional provider keys (only if using those providers directly).
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
MOONSHOTAI_API_KEY=


# ============================================================
# 6) Global Feature Toggles
# ============================================================
# false => disable embeddings + vector retrieval/indexing globally.
ENABLE_EMBEDDING=true
# false => disable organization BYOK API key management/enforcement globally.
ENABLE_ORGANIZATION_PROVIDER_KEYS=false
# In-memory cache TTL (ms) for org provider key reads (Vault).
ORG_PROVIDER_KEY_CACHE_TTL_MS=30000
# ============================================================
# 7) Vector Store (Required when ENABLE_EMBEDDING=true)
# ============================================================
QDRANT_URL=

# Optional if Qdrant auth is enabled.
QDRANT_API_KEY=

# Optional tuning.
QDRANT_COLLECTION_ATTACHMENTS=attachment_chunks_v1
QDRANT_TIMEOUT_MS=5000
QDRANT_UPSERT_BATCH_SIZE=128


# ============================================================
# 8) Provider Tool Integrations (Optional)
# ============================================================
# OpenAI file-search vector stores (comma-separated IDs)
OPENAI_FILE_SEARCH_VECTOR_STORE_IDS=

# Google file-search store names (comma-separated)
GOOGLE_FILE_SEARCH_STORE_NAMES=

# Google Vertex RAG corpus id/name
GOOGLE_VERTEX_RAG_CORPUS=

# xAI vector store IDs (comma-separated)
XAI_FILE_SEARCH_VECTOR_STORE_IDS=

# xAI MCP tool bridge
XAI_MCP_SERVER_URL=
XAI_MCP_SERVER_LABEL=


# ============================================================
# 9) Stripe Billing (Workspace subscriptions)
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_SCALE_MONTHLY=
# Others
STRIPE_PRODUCT_ENTERPRISE=


# ============================================================
# 10) Workspace Usage Quota Knobs
# ============================================================
WORKSPACE_USAGE_TARGET_MARGIN_PERCENT=

# Optional plan-specific override for Plus.
WORKSPACE_USAGE_PLUS_TARGET_MARGIN_PERCENT=

# Optional plan-specific override for Pro.
WORKSPACE_USAGE_PRO_TARGET_MARGIN_PERCENT=

# Optional plan-specific override for Scale.
WORKSPACE_USAGE_SCALE_TARGET_MARGIN_PERCENT=

# Optional plan-specific override for Enterprise.
WORKSPACE_USAGE_ENTERPRISE_TARGET_MARGIN_PERCENT=


# ============================================================
# 11) Chat Error Observability
# ============================================================
# Public PostHog project API key used by both the server and browser SDKs.
POSTHOG_PROJECT_API_KEY=

# Optional ingest host. Defaults to PostHog Cloud US.
POSTHOG_HOST=

# Required only for production source map upload during builds.
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
