{
  "name": "tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "predev": "bun run i18n:compile",
    "dev": "bun --bun vite dev --port 3000",
    "prebuild": "bun run i18n:compile",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "start:bun": "bun run .output/server/index.mjs",
    "preview": "vite preview",
    "zero-cache": "zero-cache-dev",
    "db:reset": "bun run scripts/db-reset.ts",
    "zero:reset": "bun run scripts/zero-dev-reset.ts",
    "postgres:drop-all-tables": "bun run scripts/postgres-drop-all-tables.ts",
    "pretest": "bun run i18n:compile",
    "test": "vitest run"
  },
