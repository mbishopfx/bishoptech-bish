{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "strict",
  "globalEnv": ["NODE_ENV"],
  "globalDependencies": [".env", ".env.*"],
  "globalPassThroughEnv": [
    "ZERO_UPSTREAM_DB",
    "WORKOS_API_KEY",
    "WORKOS_CLIENT_ID",
    "WORKOS_COOKIE_PASSWORD",
    "WORKOS_REDIRECT_URI",
    "WORKOS_WEBHOOK_SECRET",
    "VITE_ZERO_CACHE_URL",
    "ZERO_QUERY_URL",
    "ZERO_MUTATE_URL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET_NAME",
    "R2_PUBLIC_BASE_URL",
    "CF_MARKDOWN_WORKER_URL",
    "CF_MARKDOWN_WORKER_TOKEN",
    "CF_MARKDOWN_WORKER_TIMEOUT_MS",
    "CF_MARKDOWN_MAX_CHARS",
    "REDIS_URL",
    "AI_GATEWAY_API_KEY",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "XAI_API_KEY",
    "MISTRAL_API_KEY",
    "MOONSHOTAI_API_KEY",
    "ENABLE_EMBEDDING",
    "QDRANT_URL",
    "QDRANT_API_KEY",
    "QDRANT_COLLECTION_ATTACHMENTS",
    "QDRANT_TIMEOUT_MS",
    "QDRANT_UPSERT_BATCH_SIZE",
    "OPENAI_FILE_SEARCH_VECTOR_STORE_IDS",
    "GOOGLE_FILE_SEARCH_STORE_NAMES",
    "GOOGLE_VERTEX_RAG_CORPUS",
    "XAI_FILE_SEARCH_VECTOR_STORE_IDS",
    "XAI_MCP_SERVER_URL",
    "XAI_MCP_SERVER_LABEL",
    "CONVEX_DEPLOYMENT",
    "CONVEX_SITE_URL",
    "CONVEX_SYNC_SECRET",
    "CONVEX_SECRET_TOKEN",
    "CONVEX_ADMIN_TOKEN",
    "NEXT_PUBLIC_CONVEX_URL",
    "AUTUMN_SECRET_KEY",
    "AUTUMN_WEBHOOK_SECRET",
    "VALYU_API_KEY",
    "SUPERMEMORY_API_KEY",
    "KV_REST_API_URL",
    "KV_REST_API_TOKEN",
    "NEXT_PUBLIC_MAPBOX_TOKEN",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_DUB_PUBLISHABLE_KEY",
    "DUB_API_KEY",
    "NEXT_PUBLIC_DUB_API_HOST",
    "ADMIN_EMAILS",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.production",
        ".env.development",
        ".env.*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.development",
        ".env.*"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {},
    "format": {},
    "format:check": {},
    "check": {
      "dependsOn": ["^build"]
    },
    "check:watch": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {},
    "prepare": {
      "cache": false
    },
    "convex": {
      "cache": false,
      "persistent": true
    },
    "zero-cache": {
      "cache": false,
      "persistent": true
    }
  }
}
