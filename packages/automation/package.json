{
  "name": "@bish/automation",
  "description": "Shared BISH automation and connector runtime primitives",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src/**",
    "dist/**"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./handoff": {
      "types": "./src/handoff.ts",
      "import": "./src/handoff.ts",
      "default": "./src/handoff.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  }
}
