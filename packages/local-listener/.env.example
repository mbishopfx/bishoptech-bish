# Core BISH listener registration
BISH_BASE_URL=https://your-bish-domain.com
BISH_LISTENER_SECRET=replace-with-rotated-secret
# Set this directly if you already have ngrok/cloudflared.
# If you run `./start.sh` without it, the script will open a localtunnel URL automatically.
BISH_TUNNEL_URL=https://your-listener.ngrok.app/handoff

# Local runtime behavior
BISH_LISTENER_PORT=4343
BISH_LISTENER_WORKSPACE_DIR=/absolute/path/to/local/workspace
BISH_LISTENER_OUTPUT_DIR=/absolute/path/to/handoff-markdown
BISH_LISTENER_RUNTIME_MODE=visible
BISH_LISTENER_DEFAULT_TARGET=gemini
BISH_LISTENER_SUPPORTED_TARGETS=gemini,codex
BISH_LOCALTUNNEL_SUBDOMAIN=
BISH_LOCALTUNNEL_HOST=https://localtunnel.me

# Optional local-only integration
GITHUB_TOKEN=
