{
  "name": "Rift",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "apps/*", "apps/start/rift"],
  "packageManager": "bun@1.2.23",
  "scripts": {
    "dev": "turbo run dev convex --filter=rift --ui tui",
    "build": "turbo run build",
    "start": "bun run --filter rift start",
    "lint": "turbo run lint",
    "convex": "bun run --filter rift convex",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.3",
    "turbo": "^2.3.3"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "core-js",
    "esbuild",
    "unrs-resolver"
  ]
}
